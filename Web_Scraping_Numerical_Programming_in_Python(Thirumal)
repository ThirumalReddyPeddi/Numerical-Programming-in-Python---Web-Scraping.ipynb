        "# Create an empty list to store the movie URLs\n",
        "movie_urls = []\n",
        "\n",
        "\n",
        "# Find all anchor (<a>) tags that contain an href attribute\n",
        "for a in soup.find_all(\"a\", href=True):\n",
        "   # Extract the href (link) from the current anchor tag\n",
        "    href = a[\"href\"]\n",
        "\n",
